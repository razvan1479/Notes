{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickTasks",
  "version": "1.0.0",
  "identifier": "com.quicktasks.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "QuickTasks",
        "label": "main",
        "width": 420,
        "height": 640,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "center": true,
        "visible": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/[email protected]",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {}
}
