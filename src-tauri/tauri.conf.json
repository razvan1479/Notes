{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "QuickTasks",
  "version": "6.1.0",
  "identifier": "com.quicktasks.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "QuickTasks",
        "label": "main",
        "width": 420,
        "height": 640,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "center": false,
        "minimizable": false,
        "visible": false,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": [
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/[email protected]",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/razvan1479/Notes/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDZFQjhCRURCNEYzMUQxNEYKUldSUDBURlAyNzY0YnVXSG80dzM4STFXWmJweHZwTWMrZ0RIS1hZazRxUnA1M0xBYUxPTHEyL2EK",
      "windows": {
        "installMode": "quiet"
      }
    }
  }
}